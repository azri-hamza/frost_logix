{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "module": "commonjs",
    "target": "es2020",
    "moduleResolution": "node",
    "sourceMap": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "noImplicitThis": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false,
    "declaration": false,
    "types": [
      "node",
      "jest"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@frost-logix/shared-types": [
        "libs/shared-types/src/index.ts"
      ],
      "shared-types": [
        "libs/shared-types/src/index.ts"
      ],
      "@frost-logix/ui/button": [
        "libs/ui/button/src/index.ts"
      ],
      "@frost-logix/ui/utils": [
        "libs/ui/utils/src/index.ts"
      ],
      "@frost-logix/ui/alert-dialog": [
        "libs/ui/alert-dialog/src/index.ts"
      ]
    }
  }
}
