generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockType {
  SCHOOLS
  OTHERS
}

enum CustomerType {
  SCHOOLS
  OTHERS
}

enum UserRole {
  MANAGER
  STAFF
}

model User {
  id         String   @id @default(uuid(7)) @db.Uuid
  email      String   @unique
  password  String
  first_name String
  last_name  String
  role      UserRole @default(STAFF)
  created_at DateTime @default(now())
}

model Product {
  id          String   @id @default(uuid(7)) @db.Uuid
  name        String
  name_ar     String?
  unit        String   @default("kg")
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  batches                 Batch[]
  purchase_invoice_items PurchaseInvoiceItem[]
  grn_items               GRNItem[]
  delivery_note_items    DeliveryNoteItem[]
  sales_invoice_items     SalesInvoiceItem[]
}

model UnitOfMeasure {
  id          String   @id @default(uuid(7)) @db.Uuid
  name        String   @unique
  symbol     String
  created_at DateTime @default(now())
}

model Warehouse {
  id          String   @id @default(uuid(7)) @db.Uuid
  name       String
  location   String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  batches Batch[]
}

model Batch {
  id            String    @id @default(uuid(7)) @db.Uuid
  product_id    String    @db.Uuid
  warehouse_id  String    @db.Uuid
  quantity      Decimal   @db.Decimal(12, 3)
  unit_price    Decimal   @db.Decimal(10, 3)
  expiry_date   DateTime?
  received_date DateTime  @default(now())
  stock_type    StockType
  created_at    DateTime   @default(now())

  product   Product   @relation(fields: [product_id], references: [id])
  warehouse Warehouse @relation(fields: [warehouse_id], references: [id])
}

model Customer {
  id           String        @id @default(uuid(7)) @db.Uuid
  name        String
  type        CustomerType
  address     String?
  phone       String?
  tax_id      String?
  bank_account String?
  created_at  DateTime       @default(now())

  delivery_notes DeliveryNote[]
  sales_invoices SalesInvoice[]
}

model Supplier {
  id           String   @id @default(uuid(7)) @db.Uuid
  name        String
  address     String?
  phone       String?
  fax         String?
  tax_id      String?
  bank_account String?
  created_at  DateTime  @default(now())

  purchase_invoices   PurchaseInvoice[]
  goods_received_notes GoodsReceivedNote[]
}

model PurchaseInvoice {
  id             String   @id @default(uuid(7)) @db.Uuid
  invoice_number String  @unique
  date          DateTime
  supplier_id   String   @db.Uuid
  stock_type    StockType
  subtotal      Decimal  @db.Decimal(12, 3)
  tax          Decimal  @db.Decimal(12, 3) @default(0)
  net_total    Decimal  @db.Decimal(12, 3)
  notes        String?
  created_at   DateTime @default(now())

  supplier Supplier              @relation(fields: [supplier_id], references: [id])
  items    PurchaseInvoiceItem[]
}

model PurchaseInvoiceItem {
  id               String           @id @default(uuid(7)) @db.Uuid
  purchase_invoice_id String       @db.Uuid
  product_id       String          @db.Uuid
  quantity         Decimal          @db.Decimal(12, 3)
  unit_price       Decimal         @db.Decimal(10, 3)
  total            Decimal          @db.Decimal(12, 3)

  purchase_invoice PurchaseInvoice @relation(fields: [purchase_invoice_id], references: [id])
  product          Product          @relation(fields: [product_id], references: [id])
}

model GoodsReceivedNote {
  id           String   @id @default(uuid(7)) @db.Uuid
  grn_number   String   @unique
  date         DateTime
  supplier_id  String   @db.Uuid
  stock_type   StockType
  notes        String?
  created_at   DateTime @default(now())

  supplier Supplier @relation(fields: [supplier_id], references: [id])
  items    GRNItem[]
}

model GRNItem {
  id         String   @id @default(uuid(7)) @db.Uuid
  grn_id     String  @db.Uuid
  product_id String  @db.Uuid
  quantity   Decimal @db.Decimal(12, 3)
  unit_price Decimal @db.Decimal(10, 3)
  total      Decimal @db.Decimal(12, 3)

  grn     GoodsReceivedNote @relation(fields: [grn_id], references: [id])
  product Product          @relation(fields: [product_id], references: [id])
}

model DeliveryNote {
  id            String   @id @default(uuid(7)) @db.Uuid
  dn_number     String   @unique
  date          DateTime
  customer_id  String   @db.Uuid
  driver_name  String?
  vehicle_plate String?
  notes        String?
  created_at   DateTime @default(now())

  customer         Customer             @relation(fields: [customer_id], references: [id])
  items            DeliveryNoteItem[]
}

model DeliveryNoteItem {
  id         String   @id @default(uuid(7)) @db.Uuid
  dn_id      String  @db.Uuid
  product_id String  @db.Uuid
  quantity   Decimal @db.Decimal(12, 3)
  unit_price Decimal @db.Decimal(10, 3)
  total      Decimal @db.Decimal(12, 3)

  dn      DeliveryNote @relation(fields: [dn_id], references: [id])
  product Product     @relation(fields: [product_id], references: [id])
}

model SalesInvoice {
  id              String   @id @default(uuid(7)) @db.Uuid
  invoice_number String  @unique
  date           DateTime
  customer_id    String   @db.Uuid
  stock_type    StockType
  delivery_note_ids String[]
  subtotal      Decimal  @db.Decimal(12, 3)
  tax          Decimal  @db.Decimal(12, 3) @default(0)
  net_total    Decimal  @db.Decimal(12, 3)
  driver_name  String?
  vehicle_plate String?
  notes       String?
  created_at   DateTime @default(now())

  customer Customer           @relation(fields: [customer_id], references: [id])
  items    SalesInvoiceItem[]
}

model SalesInvoiceItem {
  id               String       @id @default(uuid(7)) @db.Uuid
  sales_invoice_id String       @db.Uuid
  product_id       String       @db.Uuid
  quantity         Decimal       @db.Decimal(12, 3)
  unit_price       Decimal      @db.Decimal(10, 3)
  total            Decimal      @db.Decimal(12, 3)

  sales_invoice SalesInvoice @relation(fields: [sales_invoice_id], references: [id])
  product      Product      @relation(fields: [product_id], references: [id])
}

